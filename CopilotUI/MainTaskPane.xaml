<UserControl x:Class="CopilotUI.MainTaskPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="320"
             Background="#F8F8F5"
             FontFamily="Segoe UI"
             FocusManager.IsFocusScope="True"
             PreviewMouseDown="OnPanePreviewMouseDown">

    <!--
        GOAL INPUT CHANGE:
        The WPF TextBox (GoalInput) has been replaced by an invisible Border named
        GoalInputPlaceholder. At runtime, TaskPaneManager creates a native WinForms
        TextBox overlay and positions it to cover this Border exactly.

        This sidesteps the Win32 focus ownership battle between SolidWorks and
        ElementHost. The native TextBox lives in its own HWND, parented directly
        into our container — the same architecture as ApiKeySetupForm which works.

        All other UI is unchanged.
    -->

    <UserControl.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#185FA5"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0C447C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#042C53"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B4B2A9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#646460"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBEBE8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GearBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#969692"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="ToolTip"         Value="API settings"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBEBE8"/>
                                <Setter Property="Foreground" Value="#444441"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sprint 1: Clarification card styles (kept for future reference, WinForms overlay handles input) -->
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- ── Header ─────────────────────────────────────────────────── -->
            <Border Background="White"
                    BorderBrush="#DADAD5"
                    BorderThickness="0,0,0,1"
                    Height="52">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="28" Height="28"
                            Background="#E6F1FB"
                            CornerRadius="6"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                        <Viewbox Width="16" Height="16">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="9" Canvas.Top="9"
                                         Width="6" Height="6" Fill="#185FA5"/>
                                <Line X1="12" Y1="4"  X2="12" Y2="9"
                                      Stroke="#185FA5" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="12" Y1="15" X2="12" Y2="20"
                                      Stroke="#185FA5" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="4"  Y1="12" X2="9"  Y2="12"
                                      Stroke="#185FA5" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="15" Y1="12" X2="20" Y2="12"
                                      Stroke="#185FA5" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Ellipse Canvas.Left="2"  Canvas.Top="2"  Width="4" Height="4" Fill="#B5D4F4"/>
                                <Ellipse Canvas.Left="18" Canvas.Top="2"  Width="4" Height="4" Fill="#B5D4F4"/>
                                <Ellipse Canvas.Left="2"  Canvas.Top="18" Width="4" Height="4" Fill="#B5D4F4"/>
                                <Ellipse Canvas.Left="18" Canvas.Top="18" Width="4" Height="4" Fill="#B5D4F4"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="AI Copilot"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#191919"/>
                        <TextBlock Text="SOLIDWORKS Design Assistant"
                                   FontSize="9" Foreground="#969692"/>
                    </StackPanel>

                    <Button x:Name="SetupKeyBtn"
                            Grid.Column="2"
                            Content="Setup"
                            Style="{StaticResource GhostBtn}"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Click="OnSetupKeyClick"/>

                    <Button x:Name="GearSettingsBtn"
                            Grid.Column="3"
                            Content="⚙"
                            Style="{StaticResource GearBtn}"
                            VerticalAlignment="Center"
                            Click="OnSetupKeyClick"/>
                </Grid>
            </Border>

            <!-- ── Goal input ─────────────────────────────────────────────── -->
            <Border Background="White"
                    BorderBrush="#DADAD5"
                    BorderThickness="0,0,0,1"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Design Goal"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#444441"
                               Margin="0,0,0,6"/>

                    <!--
                        GoalInputPlaceholder: an invisible Border that reserves the
                        exact space the WPF TextBox used to occupy.

                        At runtime, GoalInputOverlay (WinForms) is positioned to
                        cover this Border. The native TextBox sits on top of it and
                        accepts keyboard input without any Win32 focus hackery.

                        Height=72 matches the original TextBox Height="72".
                        The 2px Margin creates breathing room so the overlay border
                        doesn't clash with this Border's background.
                    -->
                    <Border x:Name="GoalInputPlaceholder"
                            Height="72"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,0,0,0"/>

                    <Button x:Name="SubmitGoalBtn"
                            Content="Generate Steps"
                            Style="{StaticResource PrimaryBtn}"
                            HorizontalAlignment="Stretch"
                            Height="34"
                            Margin="0,8,0,0"
                            IsEnabled="False"
                            Click="OnGenerateStepsClick"/>
                </StackPanel>
            </Border>

            <!-- ── Clarification Panel (Sprint 1) ─────────────────────────── -->
            <!-- WinForms overlay is positioned on top of the placeholder below -->
            <Border x:Name="ClarificationPanel"
                    Background="Transparent"
                    Padding="0,0,0,4"
                    Visibility="Collapsed">

                <!-- Placeholder: exact position+size for WinForms overlay positioning -->
                <Border x:Name="ClarificationPlaceholder"
                        MinHeight="120"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="12,0,12,0"/>
            </Border>

            <!-- ── Status bar ─────────────────────────────────────────────── -->
            <Border Background="#F1EFE8"
                    BorderBrush="#DADAD5"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="StatusDot"
                             Grid.Column="0"
                             Width="7" Height="7"
                             Fill="#1D9E75"
                             VerticalAlignment="Center"
                             Margin="0,0,7,0"/>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Text="Ready"
                               FontSize="11"
                               Foreground="#5F5E5A"
                               VerticalAlignment="Center"/>

                    <Button x:Name="FixKeyBtn"
                            Grid.Column="2"
                            Content="Fix key"
                            Style="{StaticResource GhostBtn}"
                            Foreground="#A32D2D"
                            FontSize="10"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            Click="OnSetupKeyClick"/>

                    <ProgressBar x:Name="ProgressIndicator"
                                 Grid.Column="3"
                                 Width="80" Height="4"
                                 IsIndeterminate="False"
                                 Visibility="Collapsed"
                                 Foreground="#185FA5"
                                 Background="#DADAD5"
                                 VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Step list ──────────────────────────────────────────────── -->
            <StackPanel x:Name="StepListPanel" Margin="0,4,0,8">
                <Border x:Name="EmptyState"
                        Margin="12,20,12,0"
                        Padding="16"
                        Background="White"
                        BorderBrush="#DADAD5"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="40" Height="40"
                                Background="#E6F1FB"
                                CornerRadius="20"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                                          Stroke="#185FA5" StrokeThickness="1.5"
                                          StrokeLineJoin="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="No steps yet"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#444441"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Enter a design goal above&#10;and click Generate Steps"
                                   FontSize="11" Foreground="#969692"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,4,0,0"
                                   LineHeight="18"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Error panel ────────────────────────────────────────────── -->
            <Border x:Name="ErrorPanel"
                    Background="#FFF5F5"
                    BorderBrush="#F09595"
                    BorderThickness="0,1,0,0"
                    Padding="12,10"
                    Visibility="Collapsed">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Operation failed"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#A32D2D"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="DismissErrorBtn"
                                Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource GhostBtn}"
                                Foreground="#A32D2D"
                                Padding="4,2"
                                Click="OnDismissErrorClick"/>
                    </Grid>
                    <TextBlock x:Name="ErrorMessageText"
                               TextWrapping="Wrap"
                               FontSize="11" Foreground="#791F1F"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="ErrorDiagnosisText"
                               TextWrapping="Wrap"
                               FontSize="11" Foreground="#5F5E5A"
                               FontStyle="Italic"
                               Margin="0,0,0,6"/>
                    <ItemsControl x:Name="AlternativesList"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>