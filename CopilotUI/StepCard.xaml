<UserControl x:Class="CopilotUI.StepCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300"
             FontFamily="Segoe UI">

    <Border x:Name="CardBorder"
            Background="White"
            BorderBrush="#DADAD5"
            BorderThickness="1"
            CornerRadius="8"
            Margin="8,4,8,0">
        <StackPanel>

            <!-- ── Header row: step number badge + feature name + confidence ── -->
            <Grid Margin="12,10,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="22" Height="22"
                        Background="#E6F1FB"
                        CornerRadius="11"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StepNumberBadge"
                               Text="1"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#185FA5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="FeatureText"
                           Grid.Column="1"
                           Text="Feature Name"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#191919"
                           VerticalAlignment="Center"/>

                <Border x:Name="ConfidenceBadge"
                        Grid.Column="2"
                        CornerRadius="4"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ConfidenceText"
                               FontSize="9"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- ── Summary line ── -->
            <TextBlock x:Name="SummaryText"
                       Margin="42,4,12,0"
                       FontSize="11"
                       Foreground="#646460"
                       FontStyle="Italic"
                       TextWrapping="Wrap"/>

            <!-- ── Instructions panel ── -->
            <Border x:Name="InstructionsPanel"
                    Background="#F0F4FA"
                    BorderBrush="#C8D8EE"
                    BorderThickness="0"
                    CornerRadius="6"
                    Margin="12,8,12,0"
                    Padding="10,8"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="HOW TO EXECUTE"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="#185FA5"
                               Margin="0,0,0,6"/>
                    <ItemsControl x:Name="InstructionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="›" FontSize="11" Foreground="#185FA5" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="11" Foreground="#2C3E50" TextWrapping="Wrap" LineHeight="17"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <!-- ── SPRINT 3: Status badge — shown after step is actioned ── -->
            <Border x:Name="StatusBadge"
                    CornerRadius="5"
                    Padding="10,5"
                    Margin="12,6,12,0"
                    Visibility="Collapsed">
                <TextBlock x:Name="StatusText"
                           FontSize="10"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- ── Action buttons row: Feedback (left) + ✓ Done (right) ── -->
            <Grid Margin="12,8,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Spacer -->
                <TextBlock x:Name="StatusIndicator"
                           Grid.Column="0"
                           FontSize="10"
                           FontStyle="Italic"
                           Foreground="#969692"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <!-- Feedback — opens FeedbackDialog so AI can rewrite the step -->
                <Button x:Name="FeedbackBtn"
                        Grid.Column="1"
                        Content="Feedback"
                        Margin="0,0,6,0"
                        Padding="8,4"
                        FontSize="11"
                        Cursor="Hand"
                        Click="OnFeedbackClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderBrush="#DADAD5" BorderThickness="1" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1EFE8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#5F5E5A"/>
                    </Button.Foreground>
                </Button>

                <!-- ✓ Done — user confirms step physically executed in SolidWorks -->
                <Button x:Name="LockBtn"
                        Grid.Column="2"
                        Content="✓ Done"
                        Padding="10,4"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="OnLockClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#2E7D32" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1B5E20"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>

            </Grid>

        </StackPanel>
    </Border>
</UserControl>
