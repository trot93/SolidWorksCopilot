<UserControl x:Class="CopilotUI.BatchControlBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="300"
             FontFamily="Segoe UI">

    <Border Background="#F4F3EE"
            BorderBrush="#DADAD5"
            BorderThickness="0,1,0,0"
            Padding="12,10,12,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Progress indicator — always visible during active session ── -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress bar track -->
                <Border Grid.Column="0"
                        Height="4"
                        Background="#DADAD5"
                        CornerRadius="2"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                    <Border x:Name="ProgressFill"
                            HorizontalAlignment="Left"
                            Width="0"
                            Height="4"
                            Background="#185FA5"
                            CornerRadius="2"/>
                </Border>

                <!-- Step range label e.g. "Steps 1–2 of 8" -->
                <TextBlock x:Name="ProgressLabel"
                           Grid.Column="1"
                           Text="Steps 1–2"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#646460"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- ── Action area — switches between states ── -->
            <Grid Grid.Row="1">

                <!-- STATE: Pending — both steps need confirmation -->
                <Button x:Name="MarkDoneAndNextBtn"
                        Content="Mark Both Done &amp; Generate Next Steps"
                        Height="34"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Visibility="Visible"
                        Click="OnMarkDoneAndNextClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#185FA5"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0C447C"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                </Button>

                <!-- STATE: Generating — spinner + label while AI call is in flight -->
                <StackPanel x:Name="GeneratingPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <Border Width="16" Height="16"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <!-- Rotation animation on the arc border -->
                        <Border x:Name="Spinner"
                                Width="16" Height="16"
                                BorderBrush="#185FA5"
                                BorderThickness="2"
                                CornerRadius="8"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetName="SpinnerRotate"
                                                Storyboard.TargetProperty="Angle"
                                                From="0" To="360"
                                                Duration="0:0:0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </Border>
                    <TextBlock Text="Generating next steps…"
                               FontSize="12"
                               Foreground="#185FA5"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- STATE: Complete — all steps done -->
                <Border x:Name="CompletePanel"
                        Background="#EAF3E8"
                        BorderBrush="#9FE1CB"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="✓ "
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Design complete — all steps executed."
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#2E7D32"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- STATE: Error — batch call failed -->
                <Border x:Name="ErrorPanel"
                        Background="#FFF5F5"
                        BorderBrush="#F09595"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ErrorText"
                                   Grid.Column="0"
                                   FontSize="11"
                                   Foreground="#A32D2D"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="RetryBtn"
                                Grid.Column="1"
                                Content="Retry"
                                Margin="8,0,0,0"
                                Padding="10,4"
                                FontSize="11"
                                Cursor="Hand"
                                Click="OnRetryClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#A32D2D" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#7B1C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</UserControl>
